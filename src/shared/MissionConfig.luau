function MissionConfig.getWeaponDefinition(weaponId: string?): WeaponDefinition
	local id = weaponId or MissionConfig.DefaultWeaponId
	return MissionConfig.Weapons[id] or MissionConfig.Weapons[MissionConfig.DefaultWeaponId]
end

function MissionConfig.getWeaponExperienceForNextLevel(level: number?): number
	local currentLevel = math.max(1, math.floor(level or 1))
	return MissionConfig.WeaponProgression.BaseExperienceForLevel + ((currentLevel - 1) * MissionConfig.WeaponProgression.ExperienceGrowthPerLevel)
end

function MissionConfig.getWeaponLevelFromExperience(experience: number?): (number, number, number)
	local maxLevel = MissionConfig.WeaponProgression.MaxLevel or 5
	local totalExperience = math.max(0, math.floor(experience or 0))
	local level = 1

	while level < maxLevel do
		local requirement = MissionConfig.getWeaponExperienceForNextLevel(level)
		if totalExperience < requirement then
			return level, totalExperience, requirement
		end
		totalExperience -= requirement
		level += 1
	end

	return maxLevel, totalExperience, 0
end

function MissionConfig.getMaxHealthBonus(unlocks)
	local total = 0
	for upgradeId, effect in pairs(MissionConfig.UpgradeEffects) do
		if unlocks and unlocks[upgradeId] then
			total += effect.maxHealthBonus or 0
		end
	end
	return total
end

function MissionConfig.getCosmeticDefinition(cosmeticId: string?)
	if not cosmeticId then
		return nil
	end
	return MissionConfig.Cosmetics[cosmeticId]
end

function MissionConfig.getScenario(index: number?)
	local scenarios = MissionConfig.Scenarios
	if not index then
		return scenarios[math.random(1, #scenarios)]
	end
	return scenarios[index] or scenarios[1]
end

function MissionConfig.getLayout(index: number?)
	local layouts = MissionConfig.Layouts
	if not index then
		return layouts[math.random(1, #layouts)]
	end
	return layouts[index] or layouts[1]
end

return table.freeze(MissionConfig)
